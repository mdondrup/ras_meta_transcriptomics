FASTQ_DIR="input/fastq"
REF="input/reference"
REF_FASTA=config["reference_fasta"]
REF_GFF=config["reference_gff"]
FQ_SUF=config["fastq_file_suffix"]


include: "rules/setup.smk"
include: "rules/unirefclusters.smk"


