# Speed up loading of the reference annotation in R by saving it as an RDA file after loading it once with GenomicFeatures. This is especially helpful if the annotation is large and needs to be loaded multiple times in downstream analysis.
rule load_reference_annotation:
    input:
        ancient("results/reference_annotated.gff")
    output:
        "results/reference_annotated.gff.rda"
    conda: "envs/deanalysis.yaml"
    message: "Loading the reference annotation into R and saving it as an RDA file for faster loading in downstream analysis. See the log for details: {log}"
    log: "logs/load_reference_annotation.log"
    shell:
        r"""
        Rscript -e 'library(rtracklayer); annot.gff3 <- import.gff3("{input}"); save(annot.gff3, file="{output}")' > {log} 2>&1
        """



rule de_analysis_betareg_uniref90:
    conda: "envs/deanalysis.yaml"
    input:
        counts="results/allSamples_uniref90.featureCounts",
        gff_rda="results/reference_annotated.gff.rda",
        meta_data="input/meta_data.xlsx"
    output:
        "results/de_analysis_betareg_uniref90.html"
    threads: 120
    # log: "logs/de_analysis_betareg_uniref90.log"
    params:
        min_counts=6,
        min_samples=6,
    script:
        "scripts/de_analysis_betareg.Rmd"

